rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} { allow read, write: if false; }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null && request.auth.token.email_verified == true; }
    function isOwner() { return isSignedIn() && existing().ownerId == request.auth.uid; }
    
    function isValidBid(data) {
      return data.keys().hasAll(['title', 'ownerId', 'globalTransport', 'globalWarranty', 'globalIcms', 'globalPis', 'globalCofins', 'globalIpi', 'globalIss', 'createdAt', 'updatedAt']) &&
             data.keys().size() == 11 &&
             data.title is string && data.title.size() <= 100 &&
             data.ownerId == request.auth.uid &&
             data.globalTransport is number && data.globalTransport >= 0 && data.globalTransport <= 100 &&
             data.globalWarranty is number && data.globalWarranty >= 0 && data.globalWarranty <= 100 &&
             data.globalIcms is number && data.globalIcms >= 0 && data.globalIcms <= 100 &&
             data.globalPis is number && data.globalPis >= 0 && data.globalPis <= 100 &&
             data.globalCofins is number && data.globalCofins >= 0 && data.globalCofins <= 100 &&
             data.globalIpi is number && data.globalIpi >= 0 && data.globalIpi <= 100 &&
             data.globalIss is number && data.globalIss >= 0 && data.globalIss <= 100;
    }
    
    match /bids/{bidId} {
      allow get: if isValidId(bidId) && isOwner();
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      
      allow create: if isValidId(bidId) && isSignedIn() &&
                    isValidBid(incoming()) &&
                    incoming().createdAt == request.time &&
                    incoming().updatedAt == request.time;
                    
      allow update: if isValidId(bidId) && isOwner() &&
                    isValidBid(incoming()) &&
                    incoming().createdAt == existing().createdAt &&
                    incoming().ownerId == existing().ownerId &&
                    incoming().updatedAt == request.time &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['title', 'globalTransport', 'globalWarranty', 'globalIcms', 'globalPis', 'globalCofins', 'globalIpi', 'globalIss', 'updatedAt']);
                    
      allow delete: if isValidId(bidId) && isOwner();
      
      function isValidBidItem(data) {
        return data.keys().hasAll(['manufacturer', 'quantity', 'unitValue', 'icms', 'pis', 'cofins', 'ipi', 'iss', 'transport', 'warranty', 'margin', 'createdAt', 'updatedAt']) &&
               data.keys().size() == 13 &&
               data.manufacturer is string && data.manufacturer.size() <= 200 &&
               data.quantity is number && data.quantity >= 0 &&
               data.unitValue is number && data.unitValue >= 0 &&
               data.icms is number && data.icms >= 0 && data.icms <= 100 &&
               data.pis is number && data.pis >= 0 && data.pis <= 100 &&
               data.cofins is number && data.cofins >= 0 && data.cofins <= 100 &&
               data.ipi is number && data.ipi >= 0 && data.ipi <= 100 &&
               data.iss is number && data.iss >= 0 && data.iss <= 100 &&
               data.transport is number && data.transport >= 0 && data.transport <= 100 &&
               data.warranty is number && data.warranty >= 0 && data.warranty <= 100 &&
               data.margin is number && data.margin >= 0 && data.margin <= 100;
      }
      
      function isBidOwner(bidParentId) {
        return isSignedIn() && get(/databases/$(database)/documents/bids/$(bidParentId)).data.ownerId == request.auth.uid;
      }
      
      match /items/{itemId} {
        allow get: if isValidId(itemId) && isValidId(bidId) && isBidOwner(bidId);
        allow list: if isValidId(bidId) && isBidOwner(bidId);
        
        allow create: if isValidId(itemId) && isValidId(bidId) &&
                      isBidOwner(bidId) &&
                      isValidBidItem(incoming()) &&
                      incoming().createdAt == request.time &&
                      incoming().updatedAt == request.time;
                      
        allow update: if isValidId(itemId) && isValidId(bidId) &&
                      isBidOwner(bidId) &&
                      isValidBidItem(incoming()) &&
                      incoming().createdAt == existing().createdAt &&
                      incoming().updatedAt == request.time &&
                      incoming().diff(existing()).affectedKeys().hasOnly([
                        'manufacturer', 'quantity', 'unitValue', 'icms', 'pis', 
                        'cofins', 'ipi', 'iss', 'transport', 'warranty', 'margin', 'updatedAt'
                      ]);
                      
        allow delete: if isValidId(itemId) && isValidId(bidId) && isBidOwner(bidId);
      }
    }
  }
}
